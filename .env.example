# Copy to .env. Read by the API (pydantic-settings, env_prefix AUTOCLAW_,
# nested keys use double underscores) and by docker compose for ${...} interpolation.

AUTOCLAW_ENV=development
AUTOCLAW_DEBUG=true

# Postgres from docker-compose (host port 5433). Omit to fall back to local SQLite.
AUTOCLAW_DATABASE_URL=postgresql+asyncpg://autoclaw:autoclaw@localhost:5433/autoclaw

# Required outside the test environment.
AUTOCLAW_API_KEY=replace-me-with-a-local-operator-api-key

# OpenClaw gateway
AUTOCLAW_OPENCLAW__BASE_URL=http://127.0.0.1:18789
AUTOCLAW_OPENCLAW__GATEWAY_TOKEN=replace-with-openclaw-gateway-bearer
AUTOCLAW_OPENCLAW__AGENT_ID=autoclaw-worker
AUTOCLAW_OPENCLAW__TIMEOUT_MS=120000
